# AuraGold NPI build (v35) — reproducible end-to-end.
#
#   make deps     # one-time: python deps (numpy scipy pillow)
#   make fetch    # pull every input (DEM, workings, geophysics, geology, fire, app geojson)
#   make build    # compute the model -> ../../data/npi/ tiles + grid + meta + eval
#   make all      # fetch + build
#   make rebuild  # drop the compute cache and rebuild from the fetched inputs
#   make clean    # remove ALL fetched inputs + caches (keeps the shipped data/npi output)
#
# Inputs are gitignored (see .gitignore); only the built data/npi/ output is committed.
# The compute cache (cache_*.npz) is regenerated by the same functions that ship — there is
# no orphan / cache-only path. Delete it (make rebuild) to recompute from raw inputs.

PY = python3

.PHONY: all deps fetch build rebuild clean

all: fetch build

deps:
	$(PY) -m pip install --user numpy scipy pillow

fetch:
	$(PY) extract_app_geojson.py    # dataGoldfields/dataEndowment from index.html
	$(PY) fetch_dem.py              # AWS terrarium z12 (~30 m, SRTM-derived)
	$(PY) fetch_workings.py         # VicMine gold occurrence points
	$(PY) fetch_geophys.py          # GA magnetics (TMI-RTP + analytic signal) + radiometrics (K, Th)
	$(PY) fetch_geology.py          # Vic 1:250k surface geology polygons
	$(PY) fetch_fire.py             # Vic DELWP fire-history perimeters (recent seasons)

build:
	$(PY) build_npi.py

rebuild:
	rm -f cache_*.npz
	$(PY) build_npi.py

clean:
	rm -f cache_*.npz geophys_*.npz workings.json \
	      geology_*.geojson fire_*.geojson dataGoldfields.geojson dataEndowment.geojson
	rm -rf terrain_z12
